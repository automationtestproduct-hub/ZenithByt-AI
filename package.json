{
          "name": "zenithbyt-ai",
          "private": true,
          "version": "1.0.0",
          "type": "module",
          "main": "main.cjs",
          "scripts": {
                      "dev": "vite",
                      "start": "pm2 start ecosystem.config.cjs",
                      "stop": "pm2 stop ecosystem.config.cjs",
                      "logs": "pm2 logs",
                      "build": "tsc && vite build",
                      "lint": "eslint .",
                      "preview": "vite preview",
                      "electron:build": "electron-builder -w"
          },
          "build": {
                      "appId": "com.automation.os",
                      "productName": "Automation OS",
                      "directories": {
              "output": "release"
                      },
                      "files": [
                                    "dist/**/*",
                                    "main.cjs"
                      ],
                      "win": {
                                    "target": "dir"
                      }
          },
          "dependencies": {
                      "framer-motion": "^12.38.0",
                      "lucide-react": "^1.7.0",
                      "react": "^19.2.4",
                      "react-dom": "^19.2.4",
                      "tailwindcss": "^4.2.2"
          },
          "devDependencies": {
                      "@vitejs/plugin-react": "^6.0.1",
                      "typescript": "~5.9.3",
                      "vite": "^8.0.1"
          }
}

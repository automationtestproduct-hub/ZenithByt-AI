{
        "name": "system-rebuilt",
        "private": true,
        "version": "1.0.0",
        "type": "module",
        "main": "main.cjs",
        "scripts": {
                  "dev": "vite",
                  "start": "pm2 start ecosystem.config.cjs",
                  "stop": "pm2 stop ecosystem.config.cjs",
                  "logs": "pm2 logs",
                  "build": "tsc && vite build",
                  "lint": "eslint .",
                  "preview": "vite preview",
                  "electron:build": "electron-builder -w"
        },
        "build": {
                  "appId": "com.automation.os",
                  "productName": "Automation OS",
                  "directories": {
                              "output": "release"
                  },
                  "files": [
                              "dist/**/*",
                              "main.cjs"
                  ],
                  "win": {
                              "target": "dir"
                  }
        },
        "dependencies": {
                  "@capacitor/android": "^8.3.0",
                  "@capacitor/cli": "^8.3.0",
                  "@capacitor/core": "^8.3.0",
                  "axios": "^1.14.0",
                  "express": "^5.2.1",
                  "framer-motion": "^12.38.0",
                  "lucide-react": "^1.7.0",
                  "nodemailer": "^8.0.4",
                  "prisma": "^7.6.0",
                  "puppeteer": "^24.40.0",
                  "react": "^19.2.4",
                  "react-dom": "^19.2.4",
                  "tailwindcss": "^4.2.2",
                  "tesseract.js": "^7.0.0"
        },
        "devDependencies": {
                  "@eslint/js": "^9.39.4",
                  "@types/node": "^24.12.0",
                  "@types/react": "^19.2.14",
                  "@types/react-dom": "^19.2.3",
                  "@vitejs/plugin-react": "^6.0.1",
                  "concurrently": "^9.2.1",
                  "electron": "^41.0.4",
                  "electron-builder": "^26.8.1",
                  "eslint": "^9.39.4",
                  "eslint-plugin-react-hooks": "^7.0.1",
                  "eslint-plugin-react-refresh": "^0.5.2",
                  "globals": "^17.4.0",
                  "typescript": "~5.9.3",
                  "typescript-eslint": "^8.57.0",
                  "vite": "^8.0.1",
                  "vite-plugin-pwa": "^1.2.0",
                  "wait-on": "^9.0.4"
        }
}
